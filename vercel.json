{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/service-air-conditioning", "destination": "/services/air-conditioning", "permanent": true },
    { "source": "/service-heating", "destination": "/services/heating-furnaces", "permanent": true },
    { "source": "/service-heat-pumps", "destination": "/services/heating-furnaces", "permanent": true },
    { "source": "/service-ductless-mini-splits", "destination": "/services/ductless-mini-splits", "permanent": true },
    { "source": "/service-installation", "destination": "/services/hvac-system", "permanent": true },
    { "source": "/service-commercial-hvac", "destination": "/services/hvac-system", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://hikmon-notify-khatibkareem983-7689s-projects.vercel.app; form-action 'self'; frame-ancestors 'self'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests" }
      ]
    }
  ]
}
